me","path":"RDSAuditSolutionStack/WorkerFunctionName","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.248.0"}},"DispatcherFunctionName":{"id":"DispatcherFunctionName","path":"RDSAuditSolutionStack/DispatcherFunctionName","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.248.0"}},"DiscoveryFunctionName":{"id":"DiscoveryFunctionName","path":"RDSAuditSolutionStack/DiscoveryFunctionName","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.248.0"}},"StateTableName":{"id":"StateTableName","path":"RDSAuditSolutionStack/StateTableName","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.248.0"}},"ScheduleRuleName":{"id":"ScheduleRuleName","path":"RDSAuditSolutionStack/ScheduleRuleName","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.248.0"}},"DiscoveryScheduleRuleName":{"id":"DiscoveryScheduleRuleName","path":"RDSAuditSolutionStack/DiscoveryScheduleRuleName","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.248.0"}},"S3BucketName":{"id":"S3BucketName","path":"RDSAuditSolutionStack/S3BucketName","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.248.0"}},"ConfigS3Key":{"id":"ConfigS3Key","path":"RDSAuditSolutionStack/ConfigS3Key","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.248.0"}},"AuditGlueDatabase":{"id":"AuditGlueDatabase","path":"RDSAuditSolutionStack/AuditGlueDatabase","constructInfo":{"fqn":"aws-cdk-lib.aws_glue.CfnDatabase","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Glue::Database","aws:cdk:cloudformation:props":{"catalogId":{"Ref":"AWS::AccountId"},"databaseInput":{"description":"Aurora/RDS MySQL audit logs database for Athena queries","name":"rds_audit_logs"}}}},"AuditGlueTable":{"id":"AuditGlueTable","path":"RDSAuditSolutionStack/AuditGlueTable","constructInfo":{"fqn":"aws-cdk-lib.aws_glue.CfnTable","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Glue::Table","aws:cdk:cloudformation:props":{"catalogId":{"Ref":"AWS::AccountId"},"databaseName":"rds_audit_logs","tableInput":{"description":"Aurora/RDS MySQL audit log table","name":"audit_logs","storageDescriptor":{"columns":[{"name":"timestamp","type":"string"},{"name":"serverhost","type":"string"},{"name":"username","type":"string"},{"name":"host","type":"string"},{"name":"connectionid","type":"string"},{"name":"queryid","type":"string"},{"name":"operation","type":"string"},{"name":"database","type":"string"},{"name":"object","type":"string"},{"name":"retcode","type":"string"}],"inputFormat":"org.apache.hadoop.mapred.TextInputFormat","location":"s3://aurora-audit-poc-lambda-logs-243509889692/audit-logs/","outputFormat":"org.apache.hadoop.hive.ql.io.HiveIgnoreKeyTextOutputFormat","serdeInfo":{"parameters":{"separatorChar":",","quoteChar":"'","escapeChar":"\\"},"serializationLibrary":"org.apache.hadoop.hive.serde2.OpenCSVSerde"}},"tableType":"EXTERNAL_TABLE"}}}},"QueryByUser":{"id":"QueryByUser","path":"RDSAuditSolutionStack/QueryByUser","constructInfo":{"fqn":"aws-cdk-lib.aws_athena.CfnNamedQuery","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Athena::NamedQuery","aws:cdk:cloudformation:props":{"database":"rds_audit_logs","description":"Query audit logs filtered by a specific username","name":"Audit Logs - Query By User","queryString":"-- Query audit logs by username\n-- Replace 'target_user' with the actual username\nSELECT from_unixtime(CAST(timestamp AS BIGINT) / 1000000) AS event_time,\n       serverhost, username, host,\n       CAST(connectionid AS BIGINT) AS connectionid,\n       CAST(queryid AS BIGINT) AS queryid,\n       operation, database, object,\n       CAST(retcode AS INTEGER) AS retcode\nFROM rds_audit_logs.audit_logs\nWHERE username = 'target_user'\nORDER BY timestamp DESC\nLIMIT 100;\n"}}},"QueryByTimeRange":{"id":"QueryByTimeRange","path":"RDSAuditSolutionStack/QueryByTimeRange","constructInfo":{"fqn":"aws-cdk-lib.aws_athena.CfnNamedQuery","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Athena::NamedQuery","aws:cdk:cloudformation:props":{"database":"rds_audit_logs","description":"Query audit logs within a specific time range using microsecond Unix timestamps","name":"Audit Logs - Query By Time Range","queryString":"-- Query audit logs within a time range\n-- timestamp is a microsecond Unix timestamp (e.g. 1773061248062696)\nSELECT from_unixtime(CAST(timestamp AS BIGINT) / 1000000) AS event_time,\n       serverhost, username, host,\n       CAST(connectionid AS BIGINT) AS connectionid,\n       CAST(queryid AS BIGINT) AS queryid,\n       operation, database, object,\n       CAST(retcode AS INTEGER) AS retcode\nFROM rds_audit_logs.audit_logs\nWHERE CAST(timestamp AS BIGINT) >= to_unixtime(TIMESTAMP '2024-01-01 00:00:00') * 1000000\n  AND CAST(timestamp AS BIGINT) <= to_unixtime(TIMESTAMP '2024-12-31 23:59:59') * 1000000\nORDER BY timestamp DESC\nLIMIT 100;\n"}}},"QueryFailedOps":{"id":"QueryFailedOps","path":"RDSAuditSolutionStack/QueryFailedOps","constructInfo":{"fqn":"aws-cdk-lib.aws_athena.CfnNamedQuery","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Athena::NamedQuery","aws:cdk:cloudformation:props":{"database":"rds_audit_logs","description":"Query operations that failed (retcode != 0)","name":"Audit Logs - Failed Operations","queryString":"-- Query failed operations (retcode != 0)\nSELECT from_unixtime(CAST(timestamp AS BIGINT) / 1000000) AS event_time,\n       serverhost, username, host,\n       CAST(connectionid AS BIGINT) AS connectionid,\n       CAST(queryid AS BIGINT) AS queryid,\n       operation, database, object,\n       CAST(retcode AS INTEGER) AS retcode\nFROM rds_audit_logs.audit_logs\nWHERE CAST(retcode AS INTEGER) != 0\nORDER BY timestamp DESC\nLIMIT 100;\n"}}},"QueryDDLOps":{"id":"QueryDDLOps","path":"RDSAuditSolutionStack/QueryDDLOps","constructInfo":{"fqn":"aws-cdk-lib.aws_athena.CfnNamedQuery","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Athena::NamedQuery","aws:cdk:cloudformation:props":{"database":"rds_audit_logs","description":"Query DDL operations (CREATE, ALTER, DROP, TRUNCATE)","name":"Audit Logs - DDL Operations","queryString":"-- Query DDL operations\nSELECT from_unixtime(CAST(timestamp AS BIGINT) / 1000000) AS event_time,\n       serverhost, username, host,\n       CAST(connectionid AS BIGINT) AS connectionid,\n       CAST(queryid AS BIGINT) AS queryid,\n       operation, database, object,\n       CAST(retcode AS INTEGER) AS retcode\nFROM rds_audit_logs.audit_logs\nWHERE operation IN ('CREATE', 'ALTER', 'DROP', 'TRUNCATE')\nORDER BY timestamp DESC\nLIMIT 100;\n"}}},"QueryDMLOps":{"id":"QueryDMLOps","path":"RDSAuditSolutionStack/QueryDMLOps","constructInfo":{"fqn":"aws-cdk-lib.aws_athena.CfnNamedQuery","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Athena::NamedQuery","aws:cdk:cloudformation:props":{"database":"rds_audit_logs","description":"Query DML operations (INSERT, UPDATE, DELETE)","name":"Audit Logs - DML Operations","queryString":"-- Query DML operations\nSELECT from_unixtime(CAST(timestamp AS BIGINT) / 1000000) AS event_time,\n       serverhost, username, host,\n       CAST(connectionid AS BIGINT) AS connectionid,\n       CAST(queryid AS BIGINT) AS queryid,\n       operation, database, object,\n       CAST(retcode AS INTEGER) AS retcode\nFROM rds_audit_logs.audit_logs\nWHERE operation IN ('INSERT', 'UPDATE', 'DELETE')\nORDER BY timestamp DESC\nLIMIT 100;\n"}}},"QueryUserStats":{"id":"QueryUserStats","path":"RDSAuditSolutionStack/QueryUserStats","constructInfo":{"fqn":"aws-cdk-lib.aws_athena.CfnNamedQuery","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Athena::NamedQuery","aws:cdk:cloudformation:props":{"database":"rds_audit_logs","description":"Statistics of operations grouped by username and operation type","name":"Audit Logs - User Operation Statistics","queryString":"-- Statistics of operations per user\nSELECT username,\n       operation,\n       COUNT(*) AS operation_count,\n       SUM(CASE WHEN CAST(retcode AS INTEGER) != 0 THEN 1 ELSE 0 END) AS failed_count\nFROM rds_audit_logs.audit_logs\nGROUP BY username, operation\nORDER BY operation_count DESC;\n"}}},"QueryDCLOps":{"id":"QueryDCLOps","path":"RDSAuditSolutionStack/QueryDCLOps","constructInfo":{"fqn":"aws-cdk-lib.aws_athena.CfnNamedQuery","version":"2.248.0"},"attributes":{"aws:cdk:cloudformation:type":"AWS::Athena::NamedQuery","aws:cdk:cloudformation:props":{"database":"rds_audit_logs","description":"Query DCL operations (GRANT, REVOKE)","name":"Audit Logs - DCL Operations","queryString":"-- Query DCL operations\nSELECT from_unixtime(CAST(timestamp AS BIGINT) / 1000000) AS event_time,\n       serverhost, username, host,\n       CAST(connectionid AS BIGINT) AS connectionid,\n       CAST(queryid AS BIGINT) AS queryid,\n       operation, database, object,\n       CAST(retcode AS INTEGER) AS retcode\nFROM rds_audit_logs.audit_logs\nWHERE operation IN ('GRANT', 'REVOKE')\nORDER BY timestamp DESC\nLIMIT 100;\n"}}},"GlueDatabaseName":{"id":"GlueDatabaseName","path":"RDSAuditSolutionStack/GlueDatabaseName","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.248.0"}},"GlueTableName":{"id":"GlueTableName","path":"RDSAuditSolutionStack/GlueTableName","constructInfo":{"fqn":"aws-cdk-lib.CfnOutput","version":"2.248.0"}},"CDKMetadata":{"id":"CDKMetadata","path":"RDSAuditSolutionStack/CDKMetadata","constructInfo":{"fqn":"constructs.Construct","version":"10.6.0"},"children":{"Default":{"id":"Default","path":"RDSAuditSolutionStack/CDKMetadata/Default","constructInfo":{"fqn":"aws-cdk-lib.CfnResource","version":"2.248.0"}}}},"BootstrapVersion":{"id":"BootstrapVersion","path":"RDSAuditSolutionStack/BootstrapVersion","constructInfo":{"fqn":"aws-cdk-lib.CfnParameter","version":"2.248.0"}},"CheckBootstrapVersion":{"id":"CheckBootstrapVersion","path":"RDSAuditSolutionStack/CheckBootstrapVersion","constructInfo":{"fqn":"aws-cdk-lib.CfnRule","version":"2.248.0"}}}},"Tree":{"id":"Tree","path"