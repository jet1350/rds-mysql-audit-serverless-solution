  "QueryByUser": {
   "Type": "AWS::Athena::NamedQuery",
   "Properties": {
    "Database": "rds_audit_logs",
    "Description": "Query audit logs filtered by a specific username",
    "Name": "Audit Logs - Query By User",
    "QueryString": "-- Query audit logs by username\n-- Replace 'target_user' with the actual username\nSELECT from_unixtime(CAST(timestamp AS BIGINT) / 1000000) AS event_time,\n       serverhost, username, host,\n       CAST(connectionid AS BIGINT) AS connectionid,\n       CAST(queryid AS BIGINT) AS queryid,\n       operation, database, object,\n       CAST(retcode AS INTEGER) AS retcode\nFROM rds_audit_logs.audit_logs\nWHERE username = 'target_user'\nORDER BY timestamp DESC\nLIMIT 100;\n"
   },
   "Metadata": {
    "aws:cdk:path": "RDSAuditSolutionStack/QueryByUser"
   }
  },
  "QueryByTimeRange": {
   "Type": "AWS::Athena::NamedQuery",
   "Properties": {
    "Database": "rds_audit_logs",
    "Description": "Query audit logs within a specific time range using microsecond Unix timestamps",
    "Name": "Audit Logs - Query By Time Range",
    "QueryString": "-- Query audit logs within a time range\n-- timestamp is a microsecond Unix timestamp (e.g. 1773061248062696)\nSELECT from_unixtime(CAST(timestamp AS BIGINT) / 1000000) AS event_time,\n       serverhost, username, host,\n       CAST(connectionid AS BIGINT) AS connectionid,\n       CAST(queryid AS BIGINT) AS queryid,\n       operation, database, object,\n       CAST(retcode AS INTEGER) AS retcode\nFROM rds_audit_logs.audit_logs\nWHERE CAST(timestamp AS BIGINT) >= to_unixtime(TIMESTAMP '2024-01-01 00:00:00') * 1000000\n  AND CAST(timestamp AS BIGINT) <= to_unixtime(TIMESTAMP '2024-12-31 23:59:59') * 1000000\nORDER BY timestamp DESC\nLIMIT 100;\n"
   },
   "Metadata": {
    "aws:cdk:path": "RDSAuditSolutionStack/QueryByTimeRange"
   }
  },
  "QueryFailedOps": {
   "Type": "AWS::Athena::NamedQuery",
   "Properties": {
    "Database": "rds_audit_logs",
    "Description": "Query operations that failed (retcode != 0)",
    "Name": "Audit Logs - Failed Operations",
    "QueryString": "-- Query failed operations (retcode != 0)\nSELECT from_unixtime(CAST(timestamp AS BIGINT) / 1000000) AS event_time,\n       serverhost, username, host,\n       CAST(connectionid AS BIGINT) AS connectionid,\n       CAST(queryid AS BIGINT) AS queryid,\n       operation, database, object,\n       CAST(retcode AS INTEGER) AS retcode\nFROM rds_audit_logs.audit_logs\nWHERE CAST(retcode AS INTEGER) != 0\nORDER BY timestamp DESC\nLIMIT 100;\n"
   },
   "Metadata": {
    "aws:cdk:path": "RDSAuditSolutionStack/QueryFailedOps"
   }
  },
  "QueryDDLOps": {
   "Type": "AWS::Athena::NamedQuery",
   "Properties": {
    "Database": "rds_audit_logs",
    "Description": "Query DDL operations (CREATE, ALTER, DROP, TRUNCATE)",
    "Name": "Audit Logs - DDL Operations",
    "QueryString": "-- Query DDL operations\nSELECT from_unixtime(CAST(timestamp AS BIGINT) / 1000000) AS event_time,\n       serverhost, username, host,\n       CAST(connectionid AS BIGINT) AS connectionid,\n       CAST(queryid AS BIGINT) AS queryid,\n       operation, database, object,\n       CAST(retcode AS INTEGER) AS retcode\nFROM rds_audit_logs.audit_logs\nWHERE operation IN ('CREATE', 'ALTER', 'DROP', 'TRUNCATE')\nORDER BY timestamp DESC\nLIMIT 100;\n"
   },
   "Metadata": {
    "aws:cdk:path": "RDSAuditSolutionStack/QueryDDLOps"
   }
  },
  "QueryDMLOps": {
   "Type": "AWS::Athena::NamedQuery",
   "Properties": {
    "Database": "rds_audit_logs",
    "Description": "Query DML operations (INSERT, UPDATE, DELETE)",
    "Name": "Audit Logs - DML Operations",
    "QueryString": "-- Query DML operations\nSELECT from_unixtime(CAST(timestamp AS BIGINT) / 1000000) AS event_time,\n       serverhost, username, host,\n       CAST(connectionid AS BIGINT) AS connectionid,\n       CAST(queryid AS BIGINT) AS queryid,\n       operation, database, object,\n       CAST(retcode AS INTEGER) AS retcode\nFROM rds_audit_logs.audit_logs\nWHERE operation IN ('INSERT', 'UPDATE', 'DELETE')\nORDER BY timestamp DESC\nLIMIT 100;\n"
   },
   "Metadata": {
    "aws:cdk:path": "RDSAuditSolutionStack/QueryDMLOps"
   }
  },
  "QueryUserStats": {
   "Type": "AWS::Athena::NamedQuery",
   "Properties": {
    "Database": "rds_audit_logs",
    "Description": "Statistics of operations grouped by username and operation type",
    "Name": "Audit Logs - User Operation Statistics",
    "QueryString": "-- Statistics of operations per user\nSELECT username,\n       operation,\n       COUNT(*) AS operation_count,\n       SUM(CASE WHEN CAST(retcode AS INTEGER) != 0 THEN 1 ELSE 0 END) AS failed_count\nFROM rds_audit_logs.audit_logs\nGROUP BY username, operation\nORDER BY operation_count DESC;\n"
   },
